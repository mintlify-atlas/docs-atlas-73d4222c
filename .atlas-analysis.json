  "keyFeatures": [
    "Type-safe Discord API client with Valibot validation",
    "Built-in react-query integration for data fetching",
    "tRPC procedure builders for end-to-end type safety",
    "Comprehensive coverage of Discord API endpoints",
    "Organized by resource type (guilds, channels, users, etc.)",
    "Request and response validation schemas"
  ],
  "publicApiSurface": [
    "@discordkit/client - Main SDK package",
    "@discordkit/core - Core utilities and request handling",
    "discord.setToken() - Authentication configuration",
    "getGuild(), getGuildQuery(), getGuildProcedure() - Guild endpoints",
    "getUser(), getUserQuery(), getUserProcedure() - User endpoints",
    "getChannel(), getChannelQuery(), getChannelProcedure() - Channel endpoints",
    "createMessage(), createMessageProcedure() - Message endpoints",
    "Schema exports (getGuildSchema, etc.) - Valibot validation schemas",
    "Request handlers for all Discord API resources",
    "react-query query functions (*Query exports)",
    "tRPC procedure builders (*Procedure exports)"
  ]
}
